#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "usage: hermes-gigachat MODEL PROMPT" >&2
  exit 2
fi

model="$1"
shift
prompt="$1"

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
set -a
source "$repo_root/.env"
set +a

export HOME="$PWD"
export OPENAI_BASE_URL="${GIGACHAT_BASE_URL:-https://gigachat.sberdevices.ru/v1}"
export OPENAI_API_KEY="$(
  cd "$repo_root"
  .venv/bin/python - <<'PY'
import os
from gigachat import GigaChat

client = GigaChat(
    user=os.getenv("GIGACHAT_USER"),
    password=os.getenv("GIGACHAT_PASSWORD"),
    base_url=os.getenv("GIGACHAT_BASE_URL") or None,
    verify_ssl_certs=False,
    profanity_check=False,
    timeout=60,
)
print(client.get_token().access_token)
PY
)"

HERMES_HOME="$(mktemp -d "${TMPDIR:-/tmp}/hermes_state_XXXXXX")"
export HERMES_HOME
mkdir -p "$HERMES_HOME"
cat > "$HERMES_HOME/config.yaml" <<YAML
model:
  provider: custom
  default: "$model"
  base_url: "$OPENAI_BASE_URL"
  api_key: "$OPENAI_API_KEY"
  api_mode: chat_completions
YAML

hermes --provider custom --model "$model" --yolo -z "$prompt"
rc=$?
rm -rf "$HERMES_HOME"
exit "$rc"
